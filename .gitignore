node_modules
dist
.DS_Store
*.local
coverage
.vite

# Private local audit terms — never committed. Holds the exact private strings
# (home paths, company domain, retired codenames) used only for local leak scans.
.leak-terms.local.json

# Local secrets — design-adapter GPU endpoints/tokens (bring-your-own-compute).
# NEVER commit a real Modal URL or token; only .env.example (placeholders) is tracked.
.env
.env.*
!.env.example

# Python bytecode
__pycache__/
*.pyc

# Phase 2 Python backend + run artifacts
backend/.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
backend/**/*.sqlite
backend/**/*.db
artifacts/runs/
backend/artifacts/
backend/build/
backend/*.egg-info/

# Playwright
test-results/
playwright-report/
.playwright/

# Local Claude Code settings (may hold local permission allowlists / paths)
.claude/settings.local.json

# Editor / OS / build cruft
.vscode/
.idea/
*.tsbuildinfo
*.log

# Never commit private keys or certs (belt-and-suspenders; none are tracked)
*.pem
*.key
