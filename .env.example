# Nebula — local environment. Copy to .env and fill in YOUR OWN values.
# .env is gitignored; never commit a real endpoint URL or token.

# ---- runtime ----
# NEBULA_OFFLINE=0                      # 0 = live public APIs (default); 1 = deterministic fixtures

# ---- design adapter (generative frontier) — OPTIONAL, bring-your-own-GPU ----
# Default (unset) is the deterministic preview: no GPU, no network, no credentials.
# To run real RFdiffusion backbones on YOUR OWN Modal account, deploy
# infra/modal/rfdiffusion_modal.py to your account (see docs/DESIGN_ADAPTERS.md), then set:
#
# NEBULA_DESIGN_ADAPTER=modal
# NEBULA_MODAL_RFDIFFUSION_URL=https://<you>--nebula-rfdiffusion-generate.modal.run
# NEBULA_MODAL_RFDIFFUSION_TOKEN=<the RFDIFFUSION_TOKEN you created as a Modal secret>
