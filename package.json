{
  "name": "nebula-discover",
  "version": "0.1.0",
  "private": true,
  "description": "Public, open-source discovery module concept for Nebula: turns a sensing objective into public construct hypotheses, mechanism routes, synthetic multimodal measurement signatures, rationale, uncertainty, and a claim-safe measurement handoff.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "check:bundle": "node scripts/check_bundle_budget.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gen:contracts": "cd backend && python -c \"import json;from app.api.main import app;open('openapi.json','w').write(json.dumps(app.openapi(),indent=2))\" && cd .. && openapi-typescript backend/openapi.json -o src/contracts/api.ts",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@gsap/react": "^2.1.2",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "3dmol": "^2.5.5",
    "fuse.js": "^7.4.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^5.2.0",
    "openapi-typescript": "^7.13.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.6.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  }
}
